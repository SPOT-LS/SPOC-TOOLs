local function updateNPCNameCache()
	local now = tick()
	if now - last_npc_cache_update < 2 then return end
	cached_npc_names = {}
	local seen = {}
	for npc, _ in pairs(cachedNPCs) do
		if npc and npc.Parent and not seen[npc.Name] then
			seen[npc.Name] = true
			table.insert(cached_npc_names, npc.Name)
		end
	end
	table.sort(cached_npc_names)
	last_npc_cache_update = now
end

