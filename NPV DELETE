local function canPersistFiles()
	return type(writefile) == "function" and type(readfile) == "function" and type(isfile) == "function"
end

local function migrateOldWhitelist()
	if not canPersistFiles() then return end
	pcall(function()
		if isfile(OLD_WL_STORE) then
			local raw = readfile(OLD_WL_STORE)
			local decoded = HttpService:JSONDecode(raw)
			if type(decoded) == "table" then
				whitelist = {}
				for _, name in ipairs(decoded) do
					if type(name) == "string" and name ~= "" then
						table.insert(whitelist, name)
					end
				end
			end
		end
	end)
end

local function loadAllSettings()
	if not canPersistFiles() then return end
	pcall(function()
		if isfile(CONFIG_STORE) then
			local raw = readfile(CONFIG_STORE)
			local data = HttpService:JSONDecode(raw)
			if type(data) ~= "table" then return end
			if type(data.fovSize) == "number" then fovSize = math.clamp(math.floor(data.fovSize), 0, 1000) end
			if type(data.showFovCircle) == "boolean" then showFovCircle = data.showFovCircle end
			if type(data.targetPart) == "string" then targetPart = data.targetPart end
			if type(data.aimSpeed) == "number" then aimSpeed = math.clamp(math.round(data.aimSpeed * 10) / 10, 0.1, 1) end
			if type(data.checkWalls) == "boolean" then checkWalls = data.checkWalls end
			if type(data.npcSearchRange) == "number" then npcSearchRange = math.clamp(math.floor(data.npcSearchRange), 0, RANGE_MAX) end
			if type(data.framePosX) == "number" then loadedFramePosX = data.framePosX end
			if type(data.framePosY) == "number" then loadedFramePosY = data.framePosY end
			if type(data.menuToggleXScale) == "number" then loadedMenuToggleXScale = data.menuToggleXScale end
			if type(data.menuToggleXOffset) == "number" then loadedMenuToggleXOffset = data.menuToggleXOffset end
			if type(data.menuToggleYScale) == "number" then loadedMenuToggleYScale = data.menuToggleYScale end
			if type(data.menuToggleYOffset) == "number" then loadedMenuToggleYOffset = data.menuToggleYOffset end
			if type(data.quickAimXScale) == "number" then loadedQuickAimXScale = data.quickAimXScale end
			if type(data.quickAimXOffset) == "number" then loadedQuickAimXOffset = data.quickAimXOffset end
			if type(data.quickAimYScale) == "number" then loadedQuickAimYScale = data.quickAimYScale end
			if type(data.quickAimYOffset) == "number" then loadedQuickAimYOffset = data.quickAimYOffset end
			if type(data.predictionEnabled) == "boolean" then predictionEnabled = data.predictionEnabled end
			if type(data.predictionAmount) == "number" then predictionAmount = math.clamp(math.round(data.predictionAmount * 100) / 100, 0, 50) end
			if type(data.dropEnabled) == "boolean" then dropEnabled = data.dropEnabled end
			if type(data.dropAmount) == "number" then dropAmount = math.clamp(math.round(data.dropAmount * 100) / 100, 0, 50) end
			if type(data.dropFarBoost) == "number" then dropFarBoost = math.clamp(math.floor(data.dropFarBoost), 0, 100) end
			if type(data.dropCloseCut) == "number" then dropCloseCut = math.clamp(math.floor(data.dropCloseCut), 0, 100) end
			if type(data.ignoreCanCollideWalls) == "boolean" then ignoreCanCollideWalls = data.ignoreCanCollideWalls end
			if type(data.ignoreTransparentWalls) == "boolean" then ignoreTransparentWalls = data.ignoreTransparentWalls end
			if type(data.whitelist) == "table" then
				whitelist = {}
				for _, name in ipairs(data.whitelist) do
					if type(name) == "string" and name ~= "" then
						table.insert(whitelist, name)
					end
				end
			end
			if type(data.dropPresets) == "table" then
				dropPresets = {}
				local maxId = 0
				for _, p in ipairs(data.dropPresets) do
					if type(p) == "table" and (type(p.id) == "number" or type(p.id) == "string") then
						local entry = {
							id = p.id,
							name = type(p.name) == "string" and p.name or ("Preset " .. p.id),
							r = type(p.r) == "number" and math.clamp(math.floor(p.r), 0, 255) or 255,
							g = type(p.g) == "number" and math.clamp(math.floor(p.g), 0, 255) or 60,
							b = type(p.b) == "number" and math.clamp(math.floor(p.b), 0, 255) or 60,
							dropAmount = type(p.dropAmount) == "number" and math.clamp(math.round(p.dropAmount * 100) / 100, 0, 50) or 0,
							farBoost = type(p.farBoost) == "number" and math.clamp(math.floor(p.farBoost), 0, 100) or 50,
							closeCut = type(p.closeCut) == "number" and math.clamp(math.floor(p.closeCut), 0, 100) or 50,
						}
						table.insert(dropPresets, entry)
						if entry.id > maxId then maxId = entry.id end
					end
				end
				nextPresetId = maxId + 1
			end
		else
			migrateOldWhitelist()
		end
	end)
end

saveAllSettings = function()
	if not canPersistFiles() then return end
	pcall(function()
		local payload = {
			fovSize = fovSize,
			showFovCircle = showFovCircle,
			targetPart = targetPart,
			aimSpeed = aimSpeed,
			checkWalls = checkWalls,
			npcSearchRange = npcSearchRange,
			predictionEnabled = predictionEnabled,
			predictionAmount = predictionAmount,
			dropEnabled = dropEnabled,
			dropAmount = dropAmount,
			dropFarBoost = dropFarBoost,
			dropCloseCut = dropCloseCut,
			ignoreCanCollideWalls = ignoreCanCollideWalls,
			ignoreTransparentWalls = ignoreTransparentWalls,
			whitelist = whitelist,
			dropPresets = dropPresets,
			framePosX = frame.Position.X.Offset,
			framePosY = frame.Position.Y.Offset,
		}
		if toggleButton then
			payload.menuToggleXScale = toggleButton.Position.X.Scale
			payload.menuToggleXOffset = toggleButton.Position.X.Offset
			payload.menuToggleYScale = toggleButton.Position.Y.Scale
			payload.menuToggleYOffset = toggleButton.Position.Y.Offset
		end
		if quickAimButton then
			payload.quickAimXScale = quickAimButton.Position.X.Scale
			payload.quickAimXOffset = quickAimButton.Position.X.Offset
			payload.quickAimYScale = quickAimButton.Position.Y.Scale
			payload.quickAimYOffset = quickAimButton.Position.Y.Offset
		end
		writefile(CONFIG_STORE, HttpService:JSONEncode(payload))
	end)
end

updateWhitelistDict = function()
	whitelistDict = {}
