local function confirmDuplicateLoad()
	local done = false
	local accepted = false
	local plr = Players.LocalPlayer
	if not plr then return false end
	local pg = plr:FindFirstChildOfClass("PlayerGui") or plr:WaitForChild("PlayerGui", 5)
	if not pg then return false end
	local dlg = Instance.new("ScreenGui")
	dlg.Name = "SPOC_ConfirmDlg"
	dlg.ResetOnSpawn = false
	dlg.DisplayOrder = 10000
	dlg.Parent = pg
	local box = Instance.new("Frame")
	box.Size = UDim2.new(0, S(320), 0, S(120))
	box.Position = UDim2.new(0.5, -S(160), 0.5, -S(60))
	box.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
	box.BorderSizePixel = 0
	box.Parent = dlg
	local msg = Instance.new("TextLabel")
	msg.Size = UDim2.new(1, -20, 0, 50)
	msg.Position = UDim2.new(0, 10, 0, 10)
	msg.BackgroundTransparency = 1
	msg.TextColor3 = Color3.fromRGB(255, 255, 255)
	msg.Text = "SPOC NPV AIM already active. Load again?"
	msg.Font = Enum.Font.SourceSans
	msg.TextSize = 16
	msg.TextWrapped = true
	msg.Parent = box
	local yesBtn = Instance.new("TextButton")
	yesBtn.Size = UDim2.new(0, 130, 0, 36)
	yesBtn.Position = UDim2.new(0, 20, 0, 70)
	yesBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
	yesBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	yesBtn.Text = "CONFIRM"
	yesBtn.Font = Enum.Font.SourceSansBold
	yesBtn.TextSize = 16
	yesBtn.Parent = box
	local noBtn = Instance.new("TextButton")
	noBtn.Size = UDim2.new(0, 130, 0, 36)
	noBtn.Position = UDim2.new(0, 170, 0, 70)
	noBtn.BackgroundColor3 = Color3.fromRGB(140, 40, 40)
	noBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	noBtn.Text = "ABORT"
	noBtn.Font = Enum.Font.SourceSansBold
	noBtn.TextSize = 16
	noBtn.Parent = box
	yesBtn.Activated:Connect(function()
		accepted = true
		done = true
		dlg:Destroy()
	end)
	noBtn.Activated:Connect(function()
		accepted = false
		done = true
		dlg:Destroy()
	end)
	while not done do
		RunService.Heartbeat:Wait()
	end
	return accepted
end

