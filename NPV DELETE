local function getPresetColorIndex(preset)
	for i, c in ipairs(PRESET_COLORS) do
		if preset.r == c[1] and preset.g == c[2] and preset.b == c[3] then
			return i
		end
	end
	return 1
end

local function cyclePresetColor(preset)
	local idx = getPresetColorIndex(preset)
	idx = idx % #PRESET_COLORS + 1
	local c = PRESET_COLORS[idx]
	preset.r = c[1]
	preset.g = c[2]
	preset.b = c[3]
end

local function applyDropPreset(preset)
	dropAmount = preset.dropAmount
	dropFarBoost = preset.farBoost
	dropCloseCut = preset.closeCut
	updateDropDisplay()
	if dropAdvFarBoostRefresh then dropAdvFarBoostRefresh() end
	if dropAdvCloseCutRefresh then dropAdvCloseCutRefresh() end
	saveAllSettings()
end

