local cached_npc_names = {}
local last_npc_cache_update = 0

local function updateNPCNameCache(force)
   local now = tick()
   if not force and now - last_npc_cache_update < 2 then return end
   cached_npc_names = {}
   local seen = {}
   for _, npc_data in ipairs(active_npcs) do
      local model = npc_data.model
      if model and model.Parent then
         local name = model.Name
         if not seen[name] then seen[name] = true; table.insert(cached_npc_names, name) end
      end
   end
   if #cached_npc_names == 0 then
      local descendants = Workspace:GetDescendants()
      for _, obj in ipairs(descendants) do
         if obj:IsA("Model") then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            if hum and hrp then
               local name = obj.Name
               if not seen[name] then seen[name] = true; table.insert(cached_npc_names, name) end
            end
         end
      end
   end
   table.sort(cached_npc_names)
   last_npc_cache_update = now
end

function refreshWhitelistNPCs()
   updateNPCNameCache(true)
   for _, child in ipairs(WhitelistFrame:GetChildren()) do
      if child:IsA("TextButton") then child:Destroy() end
   end
   local itemHeight = 25
   local count = 0
   for _, npcName in ipairs(cached_npc_names) do
      count = count + 1
      local npcButton = Instance.new("TextButton")
      npcButton.Name = npcName .. "_Whitelist"
      npcButton.Size = UDim2.new(1, -10, 0, itemHeight)
      npcButton.Position = UDim2.new(0, 5, 0, 0)
      npcButton.BorderSizePixel = 0
      npcButton.Text = npcName
      npcButton.Font = Enum.Font.TitilliumWeb
      npcButton.TextColor3 = Color3.fromRGB(255, 255, 255)
      npcButton.TextScaled = true
      npcButton.TextSize = 12
      npcButton.Parent = WhitelistFrame
      npcButton.ZIndex = 102
      local isWhitelisted = table.find(hitbox_whitelist, npcName) ~= nil
      npcButton.BackgroundColor3 = isWhitelisted and Color3.fromRGB(0,150,0) or Color3.fromRGB(90,90,90)
      npcButton.MouseButton1Click:Connect(function()
         local index = table.find(hitbox_whitelist, npcName)
         if index then
            table.remove(hitbox_whitelist, index)
            npcButton.BackgroundColor3 = Color3.fromRGB(90,90,90)
            for _, nd in ipairs(active_npcs) do
               if nd.model and nd.model.Name == npcName then nd.whitelist = false end
            end
         else
            table.insert(hitbox_whitelist, npcName)
            npcButton.BackgroundColor3 = Color3.fromRGB(0,150,0)
            for _, nd in ipairs(active_npcs) do
               if nd.model and nd.model.Name == npcName then nd.whitelist = true end
            end
         end
      end)
   end
   local totalHeight = count * (itemHeight + WhitelistUIListLayout.Padding.Offset)
   WhitelistFrame.CanvasSize = UDim2.new(0, 0, 0, math.max(totalHeight, 150))
end

