local function updateESPSingle(npc_data, localPos)
   local objects = npc_data.esp
   if not objects then return end
   local npc = npc_data.model
   local humanoid = npc_data.humanoid
   local hrp = npc_data.hrp
   if not npc.Parent or not humanoid or not hrp or not hrp.Parent then hideESPObjects(npc_data) return end
   if humanoid.Health <= 0 or npc_data.death_finalized or npc_data.esp_killed then finalizeNpcDeath(npc_data) return end
   local distance = (hrp.Position - localPos).Magnitude
   if distance > esp_range then for _, obj in pairs(objects) do obj.Visible = false end return end
   local head = npc:FindFirstChild("Head")
   local pos, topLeft, topRight, bottomLeft, bottomRight = getEspBoxMetrics(hrp.Position, head)
   if not pos then for _, obj in pairs(objects) do obj.Visible = false end return end
   if esp_boxes then
      objects.BoxTop.From=topLeft; objects.BoxTop.To=topRight; objects.BoxTop.Visible=true
      objects.BoxBottom.From=bottomLeft; objects.BoxBottom.To=bottomRight; objects.BoxBottom.Visible=true
      objects.BoxLeft.From=topLeft; objects.BoxLeft.To=bottomLeft; objects.BoxLeft.Visible=true
      objects.BoxRight.From=topRight; objects.BoxRight.To=bottomRight; objects.BoxRight.Visible=true
   else
      objects.BoxTop.Visible=false; objects.BoxBottom.Visible=false
      objects.BoxLeft.Visible=false; objects.BoxRight.Visible=false
   end
   if esp_names then
      objects.Name.Text=npc.Name
      objects.Name.Position=Vector2.new(pos.X, topLeft.Y-12)
      objects.Name.Visible=true
   else objects.Name.Visible=false end
   if esp_health then
      objects.Health.Text=math.floor(humanoid.Health).."/"..math.floor(humanoid.MaxHealth)
      objects.Health.Position=Vector2.new(pos.X, bottomLeft.Y+4)
      objects.Health.Visible=true
   else objects.Health.Visible=false end
   if esp_distance then
      objects.Distance.Text="["..math.floor(distance).."m]"
      objects.Distance.Position=Vector2.new(pos.X, bottomLeft.Y+(esp_health and 12 or 4))
      objects.Distance.Visible=true
   else objects.Distance.Visible=false end
   if esp_tracers then
      objects.Tracer.From=Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
      objects.Tracer.To=Vector2.new(pos.X, pos.Y)
      objects.Tracer.Visible=true
   else objects.Tracer.Visible=false end
end

local function rebuildEspNearList(localPos)
   esp_near_list = {}
   for _, npc_data in ipairs(active_npcs) do
      if npc_data.dead or npc_data.esp_killed then continue end
      local hrp = npc_data.hrp
      if not hrp or not hrp.Parent then continue end
      local humanoid = npc_data.humanoid
      if not humanoid or humanoid.Health <= 0 then finalizeNpcDeath(npc_data) continue end
      local dist = (hrp.Position - localPos).Magnitude
      if dist <= esp_range then
         table.insert(esp_near_list, {data=npc_data, dist=dist})
      else
         hideESPObjects(npc_data)
      end
   end
   table.sort(esp_near_list, function(a,b) return a.dist < b.dist end)
end

local function processEspFarCleanup(localPos)
   local count = #active_npcs
   if count == 0 then return end
   local cleanupRange = esp_range * 1.35
   for _ = 1, math.min(4, count) do
      esp_far_cleanup_index = esp_far_cleanup_index % count + 1
      local npc_data = active_npcs[esp_far_cleanup_index]
      if npc_data and npc_data.esp and npc_data.hrp and npc_data.hrp.Parent then
         if (npc_data.hrp.Position - localPos).Magnitude > cleanupRange then removeESPObjects(npc_data) end
      end
   end
end

local function removeNPC(index)
   local npc_data = active_npcs[index]
   if not npc_data then return end
   removeESPObjects(npc_data)
   if npc_data.model and npc_data.model.Parent then restoreOriginalProperties(npc_data.model) end
   npc_index_map[npc_data.model] = nil
   local last_idx = #active_npcs
   if index ~= last_idx then
      active_npcs[index] = active_npcs[last_idx]
      npc_index_map[active_npcs[index].model] = index
   end
   active_npcs[last_idx] = nil
end

local function initNPC(model)
   if npc_index_map[model] then return end
   local valid, humanoid, hrp = isValidNPC(model)
   if not valid then return end
   local npc_data = {
      model=model, humanoid=humanoid, hrp=hrp, esp=nil,
      whitelist=table.find(hitbox_whitelist, model.Name) ~= nil,
      dead=false, esp_killed=false, death_finalized=false,
      cleanup_queued=false, hitbox_restored=false, last_update=tick()
   }
   humanoid.HealthChanged:Connect(function(h) if h <= 0 then finalizeNpcDeath(npc_data) end end)
   humanoid.Died:Connect(function() finalizeNpcDeath(npc_data) end)
   humanoid:GetPropertyChangedSignal("Parent"):Connect(function() if not humanoid.Parent then killEspForNPC(npc_data) end end)
   model.AncestryChanged:Connect(function(_, parent) if not parent then killEspForNPC(npc_data) end end)
   table.insert(active_npcs, npc_data)
   npc_index_map[model] = #active_npcs
   if enable_hitbox_global then
      hitbox_priority_tail += 1
      hitbox_priority_queue[hitbox_priority_tail] = npc_data
   end
   if esp_enabled then last_esp_near_rebuild = 0 end
end

