   end
end

local function getDistanceToPartEdge(point, part)
   local pos = part.Position
   local size = part.Size / 2
   local rel = point - pos
   local closest = Vector3.new(math.clamp(rel.X,-size.X,size.X),math.clamp(rel.Y,-size.Y,size.Y),math.clamp(rel.Z,-size.Z,size.Z))
   return (point - (pos + closest)).Magnitude
end

local function shouldRestoreForMargin(npc_data)
   if collision_margin <= 0 then return false end
   local localChar = LocalPlayer.Character
   if not localChar then return false end
   local localHRP = localChar:FindFirstChild("HumanoidRootPart")
   if not localHRP then return false end
   local localPos = localHRP.Position
   for _, part_name in ipairs(hitbox_target_parts) do
      local part = npc_data.model:FindFirstChild(part_name)
      if part and part:IsA("BasePart") then
         if getDistanceToPartEdge(localPos, part) < collision_margin then return true end
      end
   end
   return false
end

local function applyHitboxToNPC(npc_data, no_collision)
   if npc_data.whitelist then return end
   local npc = npc_data.model
   ensureHitboxProperties(npc)
   local props = hitbox_original_properties[npc]
   if not props then return end
   npc_data.hitbox_restored = false
   local is_head_mode = (hitbox_mode == "Head Only")
   local hitSize = Vector3.new(hitbox_size, hitbox_size, hitbox_size)
   for part_name, original in pairs(props) do
      local part = npc:FindFirstChild(part_name)
      if part and part:IsA("BasePart") then
         if hitbox_target_set[part_name] then
            if is_head_mode and part_name == "Head" then
               part.CanCollide = not no_collision
               part.Transparency = hitbox_transparency
               part.Size = hitSize
            elseif not is_head_mode then
               part.CanCollide = not no_collision
               part.Transparency = hitbox_transparency
               part.Size = hitSize
            end
         elseif is_head_mode and body_parts_set[part_name] then
            part.CanCollide = not no_collision
            part.Transparency = 0
            part.Size = original.Size + Vector3.new(0.1,0.1,0.1)
         else
            part.Size = original.Size
            part.CanCollide = original.CanCollide
            part.Transparency = original.Transparency
         end
      end
   end
end

local function processHitboxForNPC(npc_data, localPos)
   if not npc_data or not npc_data.hrp or not npc_data.hrp.Parent then return end
   local hum = npc_data.humanoid
   local isDead = npc_data.dead or (hum and hum.Health <= 0)
   if isDead then
      if hitbox_alive_only then restoreHitboxForNPCSafe(npc_data) return end
      if npc_data.whitelist then return end
      if (localPos - npc_data.hrp.Position).Magnitude <= npc_search_range then
         if shouldRestoreForMargin(npc_data) then restoreHitboxForNPCSafe(npc_data)
         else applyHitboxToNPC(npc_data, enable_no_collision) end
      end
      return
   end
   local dist = (localPos - npc_data.hrp.Position).Magnitude
   if dist <= npc_search_range and not npc_data.whitelist then
      if shouldRestoreForMargin(npc_data) then restoreHitboxForNPCSafe(npc_data)
      else applyHitboxToNPC(npc_data, enable_no_collision) end
   else
      restoreHitboxForNPCSafe(npc_data)
   end
end

local function projectWorldToEsp(worldPos)
   local viewport, onScreen = Camera:WorldToViewportPoint(worldPos)
   if not onScreen or viewport.Z <= 0 then return nil end
   return Vector2.new(viewport.X, viewport.Y)
end

local function getEspBoxMetrics(hrpPos, head)
   if not head then return nil end
   local pos = projectWorldToEsp(hrpPos)
   local headPos = projectWorldToEsp(head.Position + Vector3.new(0,0.5,0))
   local legPos = projectWorldToEsp(hrpPos - Vector3.new(0,3,0))
   if not pos or not headPos or not legPos then return nil end
   local vs = Camera.ViewportSize
   local boxHeight = math.abs(headPos.Y - legPos.Y)
   if boxHeight < 2 or boxHeight > vs.Y * 0.75 then return nil end
   local boxWidth = math.max(boxHeight * 0.35, 2)
   if boxWidth > vs.X * 0.45 then return nil end
   local topY = math.min(headPos.Y, legPos.Y)
   local bottomY = math.max(headPos.Y, legPos.Y)
   local topLeft = Vector2.new(pos.X - boxWidth/2, topY)
   local topRight = Vector2.new(pos.X + boxWidth/2, topY)
   local bottomLeft = Vector2.new(pos.X - boxWidth/2, bottomY)
   local bottomRight = Vector2.new(pos.X + boxWidth/2, bottomY)
   local margin = 8
   if topLeft.X < -margin or topRight.X > vs.X + margin then return nil end
   if topLeft.Y < -margin or bottomLeft.Y > vs.Y + margin then return nil end
   return pos, topLeft, topRight, bottomLeft, bottomRight
end

