local function addSlider(name, min, max, default, funct, ...)
   ensureSliderInput()
   local newSlider = Slider:Clone()
   local args = {...}
   local value = default
   local range = math.max(max - min, 1)
   local sliderBar = newSlider:WaitForChild("SliderBar")
   local sliderBtn = sliderBar:WaitForChild("SliderButton")
   local sliderNameLabel = newSlider:WaitForChild("SliderName")
   local function updateSlider(input)
      local barW = sliderBar.AbsoluteSize.X
      if barW <= 0 then return end
      local pos = math.clamp((input.Position.X - sliderBar.AbsolutePosition.X) / barW, 0, 1)
      local newVal = math.floor(min + range * pos)
      if newVal == value then return end
      value = newVal
      sliderBtn.Position = UDim2.new(pos, 0, 0.5, 0)
      sliderNameLabel.Text = name .. ": " .. value
      funct(value, unpack(args))
   end
   local entry = {bar = sliderBar, update = updateSlider}
   sliderBtn.InputBegan:Connect(function(input)
      if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
         active_slider_drag = entry; updateSlider(input)
      end
   end)
   slider_registry[newSlider] = entry
