local auto_click_key = "F"
local auto_click_duration = 3
local auto_click_speed = 50000
local auto_click_running = false
local auto_click_last_end = 0
local AUTO_CLICK_COOLDOWN = 5

local clickBtn = Button:Clone()
clickBtn:WaitForChild("Name").Text = "Auto Click: Ready (Tap)"
clickBtn.Size = UDim2.new(0.95, 0, 0, element_height)
clickBtn.Parent = Menu
clickBtn.LayoutOrder = elements
clickBtn.Visible = true
elements += 1
addSpace(Menu)

local keyInput = Instance.new("TextBox")
keyInput.Size = UDim2.new(0.95, 0, 0, 22)
keyInput.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
keyInput.TextColor3 = Color3.fromRGB(255, 255, 255)
keyInput.PlaceholderText = "Input Key (e.g. F)"
keyInput.Text = "F"
keyInput.Font = Enum.Font.TitilliumWeb
keyInput.TextScaled = true
keyInput.ClearTextOnFocus = false
keyInput.Parent = Menu
keyInput.LayoutOrder = elements
elements += 1
addSpace(Menu)

local function updateClickBtnState()
   if auto_click_running then
      clickBtn:WaitForChild("Name").Text = "Auto Click: RUNNING..."
      return
   end
   local now = tick()
   local elapsed = now - auto_click_last_end
   if elapsed < AUTO_CLICK_COOLDOWN then
      clickBtn:WaitForChild("Name").Text = "Cooldown: " .. math.ceil(AUTO_CLICK_COOLDOWN - elapsed) .. "s"
   else
      clickBtn:WaitForChild("Name").Text = "Auto Click: Ready (Tap)"
   end
end

RunService.Heartbeat:Connect(function()
   if auto_click_running then return end
   if auto_click_last_end <= 0 then return end
   if tick() - auto_click_last_end >= AUTO_CLICK_COOLDOWN then return end
   updateClickBtnState()
end)

clickBtn.MouseButton1Click:Connect(function()
   if auto_click_running then return end
   local now = tick()
   if now - auto_click_last_end < AUTO_CLICK_COOLDOWN then return end
   local key = keyInput.Text:upper()
   if #key ~= 1 then
      clickBtn:WaitForChild("Name").Text = "Invalid Key!"
      task.delay(1, updateClickBtnState)
      return
   end
   local keyCode = Enum.KeyCode[key]
   if not keyCode then
      clickBtn:WaitForChild("Name").Text = "Invalid Key!"
      task.delay(1, updateClickBtnState)
      return
   end
   auto_click_key = key
   auto_click_running = true
   updateClickBtnState()
   task.spawn(function()
      local ok, vim = pcall(function() return game:GetService("VirtualInputManager") end)
      if not ok or not vim then
         auto_click_running = false
         auto_click_last_end = tick()
         clickBtn:WaitForChild("Name").Text = "VIM N/A"
         task.delay(1, updateClickBtnState)
         return
      end
      local startTime = tick()
      local interval = 1 / math.max(1, auto_click_speed)
      while tick() - startTime < auto_click_duration do
         pcall(function()
            vim:SendKeyEvent(true, keyCode, false, game)
            task.wait(interval / 2)
            vim:SendKeyEvent(false, keyCode, false, game)
         end)
         task.wait(interval)
      end
      auto_click_running = false
      auto_click_last_end = tick()
      updateClickBtnState()
   end)
end)

addSlider("Click Duration (sec)", 1, 60, 3, function(value) auto_click_duration = value end)
addSlider("Click Speed (per sec)", 5000, 50000, 50000, function(value) auto_click_speed = value end)

if instant_interact_enabled then
   task.spawn(function()
      local descendants = Workspace:GetDescendants()
      for i, obj in ipairs(descendants) do
         if obj:IsA("ProximityPrompt") then
            if original_hold_durations[obj] == nil then original_hold_durations[obj] = obj.HoldDuration end
            table.insert(cached_prompts, obj)
            obj.HoldDuration = 0
         end
         if i % 400 == 0 then task.wait() end
      end
   end)
end

