local function saveOriginalProperties(npc)
   if hitbox_original_properties[npc] then return end
   local props = {}
   for _, part_name in ipairs(all_hitbox_parts) do
      local part = npc:FindFirstChild(part_name)
      if part and part:IsA("BasePart") then
         props[part_name] = {Size=part.Size, CanCollide=part.CanCollide, Transparency=part.Transparency}
      end
   end
   hitbox_original_properties[npc] = props
end

local function ensureHitboxProperties(npc)
   if not hitbox_original_properties[npc] then saveOriginalProperties(npc) end
end

local function restoreOriginalProperties(npc)
   local props = hitbox_original_properties[npc]
   if not props then return end
   for part_name, original in pairs(props) do
      local part = npc:FindFirstChild(part_name)
      if part and part:IsA("BasePart") then
         part.Size = original.Size
         part.CanCollide = original.CanCollide
         part.Transparency = original.Transparency
      end
   end
end

local function restoreHitboxForNPCSafe(npc_data)
   if not npc_data then return end
   if npc_data.hitbox_restored then return end
   if npc_data.model and npc_data.model.Parent then
      restoreOriginalProperties(npc_data.model)
   end
   npc_data.hitbox_restored = true
end

local function restoreHitboxForNPC(npc_data)
