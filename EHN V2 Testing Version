      if part:IsA("BasePart") and noclip_original_states[part] == nil then
         noclip_original_states[part] = part.CanCollide
      end
   end
end

local function apply_noclip_to_character(character)
   if not character then return end
   for _, part in ipairs(character:GetDescendants()) do
      if part:IsA("BasePart") then
         if noclip_original_states[part] == nil then noclip_original_states[part] = part.CanCollide end
         part.CanCollide = false
      end
   end
end

local function restore_noclip_states()
   for part, original_state in pairs(noclip_original_states) do
