local function process_prompt_queues()
   for _, prompt in ipairs(prompt_add_queue) do
      if prompt and prompt.Parent then
         if original_hold_durations[prompt] == nil then original_hold_durations[prompt] = prompt.HoldDuration end
         table.insert(cached_prompts, prompt)
         if instant_interact_enabled then prompt.HoldDuration = 0 end
      end
   end
   prompt_add_queue = {}
   for _, prompt in ipairs(prompt_remove_queue) do
      for i, cached in ipairs(cached_prompts) do
         if cached == prompt then table.remove(cached_prompts, i) break end
      end
      original_hold_durations[prompt] = nil
   end
   prompt_remove_queue = {}
end

local lastAutoInteract = 0
local AUTO_INTERACT_INTERVAL = 0.15

local function updateAutoInteract()
   if not auto_interact_enabled then return end
   local now = tick()
   if now - lastAutoInteract < AUTO_INTERACT_INTERVAL then return end
   lastAutoInteract = now
   local character = LocalPlayer.Character
   if not character then return end
   local hrp = character:FindFirstChild("HumanoidRootPart")
   if not hrp then return end
   local localPos = hrp.Position
   for _, obj in ipairs(cached_prompts) do
      if obj and obj.Parent and obj.Parent:IsA("BasePart") then
         local dist = (localPos - obj.Parent.Position).Magnitude
         if dist <= interact_distance and dist <= obj.MaxActivationDistance then
            pcall(function()
               if obj.Enabled and typeof(fireproximityprompt) == "function" then
                  fireproximityprompt(obj)
               end
            end)
         end
      end
   end
end

RunService.Heartbeat:Connect(function()
   local nowHb = tick()
   if WhitelistButton.Visible and nowHb - last_whitelist_pos_update >= WHITELIST_POS_INTERVAL then
      last_whitelist_pos_update = nowHb
      updateWhitelistButtonPosition()
   end
   process_prompt_queues()
   updateAutoInteract()

   local cleanBatch = math.min(CLEANUP_BATCH_SIZE, npc_cleanup_tail - npc_cleanup_head + 1)
   for _ = 1, cleanBatch do
      local npc_data = npc_cleanup_queue[npc_cleanup_head]
      npc_cleanup_queue[npc_cleanup_head] = nil
      npc_cleanup_head += 1
      if npc_data and npc_data.model then
         local idx = npc_index_map[npc_data.model]
         if idx then removeNPC(idx) end
      end
   end

   local localChar = LocalPlayer.Character
   local localHRP = localChar and localChar:FindFirstChild("HumanoidRootPart")
   if not localHRP then return end
   local localPos = localHRP.Position

   if enable_hitbox_global then
      local count = #active_npcs
      if count > 0 then
         local batch = math.min(HITBOX_BATCH_SIZE, count)
         local processed = 0
         while processed < batch and hitbox_priority_head <= hitbox_priority_tail do
            local npc_data = hitbox_priority_queue[hitbox_priority_head]
            hitbox_priority_queue[hitbox_priority_head] = nil
            hitbox_priority_head += 1
            processHitboxForNPC(npc_data, localPos)
            processed += 1
         end
         for _ = processed + 1, batch do
            hitbox_update_rotary_index = hitbox_update_rotary_index % count + 1
            processHitboxForNPC(active_npcs[hitbox_update_rotary_index], localPos)
         end
      end
   end
end)

RunService.RenderStepped:Connect(function()
   if not esp_enabled then return end
   local localChar = LocalPlayer.Character
   local localHRP = localChar and localChar:FindFirstChild("HumanoidRootPart")
   if not localHRP then return end
   local localPos = localHRP.Position
   local now = tick()
   local rebuildInterval = math.max(esp_update_interval, ESP_NEAR_REBUILD_INTERVAL)
   if now - last_esp_near_rebuild >= rebuildInterval then
      rebuildEspNearList(localPos)
      last_esp_near_rebuild = now
      processEspFarCleanup(localPos)
   end
   local nearCount = #esp_near_list
   if nearCount == 0 then return end
   local batch = math.min(ESP_MAX_FRAME_UPDATES, nearCount)
   for _ = 1, batch do
      esp_draw_index = esp_draw_index % nearCount + 1
      local entry = esp_near_list[esp_draw_index]
      if not entry then break end
      local npc_data = entry.data
      if npc_data.death_finalized or npc_data.esp_killed then
      elseif npc_data.humanoid and npc_data.humanoid.Health <= 0 then
         finalizeNpcDeath(npc_data)
      else
         if not npc_data.esp then npc_data.esp = createESPObjects() end
         if npc_data.esp then updateESPSingle(npc_data, localPos) end
      end
   end
end)

