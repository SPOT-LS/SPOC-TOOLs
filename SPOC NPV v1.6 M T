local cached_npc_names = {}
local last_npc_cache_update = 0

local function updateNPCNameCache()
	local now = tick()
	if now - last_npc_cache_update < 2 then return end
	cached_npc_names = {}
	local seen = {}
	for npc, _ in pairs(cachedNPCs) do
		if npc and npc.Parent and not seen[npc.Name] then
			seen[npc.Name] = true
			table.insert(cached_npc_names, npc.Name)
		end
	end
	table.sort(cached_npc_names)
	last_npc_cache_update = now
end

local function recalcNextPresetId()
	local maxId = 0
	for _, p in ipairs(dropPresets) do
		if type(p.id) == "number" and p.id > maxId then
			maxId = p.id
		end
	end
	nextPresetId = maxId + 1
end

local function applyParamsSnapshot(data)
	if type(data) ~= "table" then return end
	if type(data.fovSize) == "number" then fovSize = math.clamp(math.floor(data.fovSize), 0, 1000) end
	if type(data.showFovCircle) == "boolean" then showFovCircle = data.showFovCircle end
	if type(data.targetPart) == "string" then targetPart = data.targetPart end
	if type(data.aimSpeed) == "number" then aimSpeed = math.clamp(math.round(data.aimSpeed * 10) / 10, 0.1, 1) end
	if type(data.checkWalls) == "boolean" then checkWalls = data.checkWalls end
	if type(data.npcSearchRange) == "number" then npcSearchRange = math.clamp(math.floor(data.npcSearchRange), 0, RANGE_MAX)
	elseif type(data.playerSearchRange) == "number" then npcSearchRange = math.clamp(math.floor(data.playerSearchRange), 0, RANGE_MAX) end
	if type(data.predictionEnabled) == "boolean" then predictionEnabled = data.predictionEnabled end
	if type(data.predictionAmount) == "number" then predictionAmount = math.clamp(math.round(data.predictionAmount * 100) / 100, 0, 50) end
	if type(data.dropEnabled) == "boolean" then dropEnabled = data.dropEnabled end
	if type(data.dropAmount) == "number" then dropAmount = math.clamp(math.round(data.dropAmount * 100) / 100, 0, 50) end
	if type(data.dropFarBoost) == "number" then dropFarBoost = math.floor(data.dropFarBoost) end
	if type(data.dropCloseCut) == "number" then dropCloseCut = math.floor(data.dropCloseCut) end
	if type(data.ignoreCanCollideWalls) == "boolean" then ignoreCanCollideWalls = data.ignoreCanCollideWalls end
	if type(data.ignoreTransparentWalls) == "boolean" then ignoreTransparentWalls = data.ignoreTransparentWalls end
	if type(data.whitelist) == "table" then
		whitelist = {}
		for _, name in ipairs(data.whitelist) do
			if type(name) == "string" and name ~= "" then
				table.insert(whitelist, name)
			end
		end
	end
	if type(data.nearPriorityEnabled) == "boolean" then nearPriorityEnabled = data.nearPriorityEnabled end
	if type(data.nearPriorityRange) == "number" then nearPriorityRange = math.clamp(math.floor(data.nearPriorityRange), 0, RANGE_MAX) end
	if type(data.dropPresets) == "table" then
		dropPresets = {}
		for _, p in ipairs(data.dropPresets) do
			if type(p) == "table" and (type(p.id) == "number" or type(p.id) == "string") then
				table.insert(dropPresets, cloneTable(p))
			end
		end
		recalcNextPresetId()
	end
	if type(data.quickAimButtonPos) == "table" and quickAimButton then
		local p = data.quickAimButtonPos
		if type(p.xScale) == "number" and type(p.xOffset) == "number" and type(p.yScale) == "number" and type(p.yOffset) == "number" then
			quickAimButton.Position = UDim2.new(p.xScale, p.xOffset, p.yScale, p.yOffset)
		end
	end
	if type(data.toggleButtonPos) == "table" and toggleButton then
		local p = data.toggleButtonPos
		if type(p.xScale) == "number" and type(p.xOffset) == "number" and type(p.yScale) == "number" and type(p.yOffset) == "number" then
			toggleButton.Position = UDim2.new(p.xScale, p.xOffset, p.yScale, p.yOffset)
		end
	end
	updateWhitelistDict()
	wallCheckParamsVersion = wallCheckParamsVersion + 1
	lastWallCheckVersion = wallCheckParamsVersion
	for _, cached in pairs(cachedNPCs) do
		if cached then
			cached.lastWallCheck = 0
			if cached.npc and cached.npc.Parent then
				cached.targetPartObj = getTargetPartFunc(cached.npc, targetPart)
			end
		end
	end
	if refreshAllUI then refreshAllUI() end
	if dropAdvFarBoostRefresh then dropAdvFarBoostRefresh() end
	if dropAdvCloseCutRefresh then dropAdvCloseCutRefresh() end
	if refreshDropPresetsList then refreshDropPresetsList() end
	if refreshNearPanelDisplays then refreshNearPanelDisplays() end
	aimFovSyncActive = true
	refreshFovVisibility()
	if type(data.isSilentAimEnabled) == "boolean" then
		if data.isSilentAimEnabled ~= isSilentAimEnabled then
			if toggleSilentAim then toggleSilentAim() end
		else
			syncQuickAimButton()
		end
	end
end

local function createDropAdvSliderRow(parent, yPos, labelText, getVal, setVal, onChanged)
	local rowLabel = Instance.new("TextLabel")
	rowLabel.Size = UDim2.new(1, 0, 0, 14)
	rowLabel.Position = UDim2.new(0, 0, 0, yPos)
	rowLabel.BackgroundTransparency = 1
	rowLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	rowLabel.Text = labelText .. ": " .. getVal()
	rowLabel.Font = Enum.Font.SourceSans
	rowLabel.TextSize = 11
	rowLabel.TextXAlignment = Enum.TextXAlignment.Left
	rowLabel.Parent = parent
	local rowFrame = Instance.new("Frame")
	rowFrame.Size = UDim2.new(1, 0, 0, 18)
	rowFrame.Position = UDim2.new(0, 0, 0, yPos + 14)
	rowFrame.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
	rowFrame.BorderSizePixel = 0
	rowFrame.Parent = parent
	local decBtn = Instance.new("TextButton")
	decBtn.Size = UDim2.new(0.2, 0, 1, 0)
	decBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
	decBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	decBtn.Text = "-"
	decBtn.Font = Enum.Font.SourceSansBold
	decBtn.TextSize = 14
	decBtn.Parent = rowFrame
	local inputBox = Instance.new("TextBox")
	inputBox.Size = UDim2.new(0.6, 0, 1, 0)
	inputBox.Position = UDim2.new(0.2, 0, 0, 0)
	inputBox.BackgroundColor3 = Color3.fromRGB(120, 120, 120)
	inputBox.TextColor3 = Color3.fromRGB(255, 255, 255)
	inputBox.Text = tostring(getVal())
	inputBox.Font = Enum.Font.SourceSans
	inputBox.TextSize = 12
	inputBox.ClearTextOnFocus = false
	inputBox.Parent = rowFrame
	local incBtn = Instance.new("TextButton")
	incBtn.Size = UDim2.new(0.2, 0, 1, 0)
	incBtn.Position = UDim2.new(0.8, 0, 0, 0)
	incBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
	incBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	incBtn.Text = "+"
	incBtn.Font = Enum.Font.SourceSansBold
	incBtn.TextSize = 14
	incBtn.Parent = rowFrame
	local function refresh()
		local v = getVal()
		rowLabel.Text = labelText .. ": " .. v
		inputBox.Text = tostring(v)
	end
	local function applyNum(num)
		if not num then
			refresh()
			return
		end
		num = math.floor(num + 0.5)
		setVal(num)
		refresh()
		if onChanged then onChanged() end
	end
	decBtn.Activated:Connect(function()
		applyNum(getVal() - 1)
	end)
	incBtn.Activated:Connect(function()
		applyNum(getVal() + 1)
	end)
	inputBox.FocusLost:Connect(function()
		applyNum(tonumber(inputBox.Text))
	end)
	return refresh
end

