local function handleSliderTouch(sliderFrame, updateFunc, onRelease)
	local isSliding = false
	local touchConnection = nil
	sliderFrame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			isSliding = true
			local relativeX = math.clamp((input.Position.X - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
			updateFunc(relativeX)
			local touchId = input.UserInputType == Enum.UserInputType.Touch and input.Touch and input.Touch.TouchId or nil
			if touchConnection then
				touchConnection:Disconnect()
				touchConnection = nil
			end
			touchConnection = UserInputService.InputChanged:Connect(function(inputChanged)
				if not isSliding then return end
				if inputChanged.UserInputType == Enum.UserInputType.Touch and touchId and inputChanged.Touch and inputChanged.Touch.TouchId == touchId then
					relativeX = math.clamp((inputChanged.Position.X - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
					updateFunc(relativeX)
				elseif inputChanged.UserInputType == Enum.UserInputType.MouseMovement and not touchId then
					relativeX = math.clamp((inputChanged.Position.X - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
					updateFunc(relativeX)
				end
			end)
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if not isSliding then return end
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			isSliding = false
			if touchConnection then
				touchConnection:Disconnect()
				touchConnection = nil
			end
			if onRelease then onRelease() end
		end
	end)
end

