local function getFovShouldShow()
	if isSilentAimEnabled then
		return showFovCircle
	end
	if not aimFovSyncActive then
		return showFovCircle
	end
	return false
end

function updateFovCircle()
	if fovCircle and fovGui then
		fovCircle.Size = UDim2.new(0, fovSize * 2, 0, fovSize * 2)
		fovCircle.Position = UDim2.new(0.5, 0, 0.5, 0)
		fovCircle.AnchorPoint = Vector2.new(0.5, 0.5)
		fovCircle.Visible = getFovShouldShow()
	end
end

refreshFovVisibility = function()
	local shouldShow = getFovShouldShow()
	if shouldShow then
		if not fovCircle then createFovCircle() end
		updateFovCircle()
	elseif fovCircle then
		fovCircle.Visible = false
	end
end

local function getTargetPartFunc(character, partName)
	if not character then return nil end
	if partName == "Torso" then
		return character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
	elseif partName == "HumanoidRootPart" then
		return character:FindFirstChild("HumanoidRootPart")
	elseif partName == "Left Arm" then
		return character:FindFirstChild("LeftUpperArm") or character:FindFirstChild("Left Arm")
	elseif partName == "Right Arm" then
		return character:FindFirstChild("RightUpperArm") or character:FindFirstChild("Right Arm")
	elseif partName == "Left Leg" then
		return character:FindFirstChild("LeftLowerLeg") or character:FindFirstChild("Left Leg")
	elseif partName == "Right Leg" then
		return character:FindFirstChild("RightLowerLeg") or character:FindFirstChild("Right Leg")
	elseif partName == "Head" then
		return character:FindFirstChild("Head")
	end
	return nil
end

local function resolveTargetVelocity(targetPartObj, targetRootPart, data)
	local vel = Vector3.zero
	if targetRootPart then
		vel = targetRootPart.AssemblyLinearVelocity
		if vel.Magnitude < 0.01 then
			vel = targetRootPart.Velocity
		end
	end
	if data and data.lastPartPos and data.lastPredTick then
		local now = tick()
		local dt = now - data.lastPredTick
		if dt > 0.001 and dt < 0.35 then
			local deltaVel = (targetPartObj.Position - data.lastPartPos) / dt
			if deltaVel.Magnitude > 0.5 then
				if vel.Magnitude < 1 or deltaVel.Magnitude > vel.Magnitude * 0.85 then
					vel = deltaVel
				end
			end
		end
	end
	if vel.Magnitude < 0.01 and data and data.lastRootPos and data.lastRootTick then
		local dt = tick() - data.lastRootTick
		if dt > 0.001 and dt < 0.35 and targetRootPart then
			local rootDelta = (targetRootPart.Position - data.lastRootPos) / dt
			if rootDelta.Magnitude > 0.5 then
				vel = rootDelta
			end
		end
	end
	return vel
end

local function sampleTargetMotion(data, targetPartObj, targetRootPart)
	if not data or not targetPartObj then return end
	local now = tick()
	data.lastPartPos = targetPartObj.Position
	data.lastPredTick = now
	if targetRootPart then
		data.lastRootPos = targetRootPart.Position
		data.lastRootTick = now
	end
end

local function getPredictedPosition(targetPartObj, targetRootPart, data)
	if not targetPartObj then return nil end
	sampleTargetMotion(data, targetPartObj, targetRootPart)
	if not predictionEnabled or predictionAmount <= 0 then
		return targetPartObj.Position
	end
	local vel = resolveTargetVelocity(targetPartObj, targetRootPart, data)
	return targetPartObj.Position + (vel * predictionAmount * 0.1)
end

local function applyBallisticElev(localPos, aimPos)
	if not dropEnabled or dropAmount <= 0 then
		return aimPos
	end
	local dist = (aimPos - localPos).Magnitude
	if dist < 1 then
		return aimPos
	end
	local refDist = math.clamp(npcSearchRange * 0.4, 60, 500)
	local curvePower = 1.5 + (dropFarBoost / 100) * 2.5
	local nearDist = 10 + ((100 - dropCloseCut) / 100) * 40
	local strength = 0.008 + (dropFarBoost / 100) * 0.025
	local rangeRatio = dist / refDist
	local ballisticCurve = math.pow(rangeRatio, curvePower)
	local nearBlend = math.clamp(dist / nearDist, 0, 1)
	ballisticCurve = ballisticCurve * nearBlend
	local elev = dropAmount * ballisticCurve * refDist * strength
	return aimPos + Vector3.new(0, elev, 0)
end

local function getFinalAimPoint(targetPartObj, targetRootPart, data, localPos)
	local predicted = getPredictedPosition(targetPartObj, targetRootPart, data)
	if not predicted then return nil end
	return applyBallisticElev(localPos, predicted)
end

local function isWithinRangeSqr(pos1, pos2, rangeSqr)
	local dx = pos1.X - pos2.X
	local dy = pos1.Y - pos2.Y
	local dz = pos1.Z - pos2.Z
	return (dx * dx + dy * dy + dz * dz) <= rangeSqr
end

local function cacheNPC(npc)
	if not npc or not npc.Parent then return end
	local isValid, hrp = isValidNPC(npc)
	if not isValid then return end
	local humanoid = npc:FindFirstChildWhichIsA("Humanoid")
	local targetPartObj = getTargetPartFunc(npc, targetPart)
	if humanoid and hrp and targetPartObj then
		local now = tick()
		cachedNPCs[npc] = {
			npc = npc,
			hrp = hrp,
			humanoid = humanoid,
			targetPartObj = targetPartObj,
			lastUpdate = now,
			lastWallCheck = 0,
			canSee = false,
			wallCheckVersion = 0,
			lastPartPos = targetPartObj.Position,
			lastPredTick = now,
			lastRootPos = hrp.Position,
			lastRootTick = now
		}
	end
end

local function uncacheNPC(npc)
	cachedNPCs[npc] = nil
end

local function checkWall(cameraPos, targetPos, targetNPC)
	local direction = targetPos - cameraPos
	local maxDistance = direction.Magnitude
	if maxDistance < 0.01 then return true end
	direction = direction.Unit
	resetWallBlacklist()
	local blacklist = wallBlacklist
	local currentDistance = maxDistance
	local currentOrigin = cameraPos
	for _ = 1, 50 do
		if currentDistance <= 0.01 then return true end
		wallRayParams.FilterDescendantsInstances = blacklist
		local raycastResult = Workspace:Raycast(currentOrigin, direction * currentDistance, wallRayParams)
		if not raycastResult then return true end
		local hitInstance = raycastResult.Instance
		if hitInstance:IsDescendantOf(targetNPC) then
			return true
		end
		local shouldIgnore = false
		if ignoreCanCollideWalls and not hitInstance.CanCollide then
			shouldIgnore = true
		elseif ignoreTransparentWalls and hitInstance.Transparency > 0.9 then
			shouldIgnore = true
		end
		if shouldIgnore then
			table.insert(blacklist, hitInstance)
			currentOrigin = raycastResult.Position
			currentDistance = (targetPos - currentOrigin).Magnitude
		else
			return false
		end
	end
	return false
end

local lastEmergencyScan = 0

local function emergencyScan()
	local now = tick()
	if now - lastEmergencyScan < 0.5 then return end
	lastEmergencyScan = now
	for _, obj in ipairs(Workspace:GetChildren()) do
		if obj:IsA("Model") and not cachedNPCs[obj] then
			cacheNPC(obj)
		end
	end
end

function silentAim()
	if not isSilentAimEnabled and not isHoldingAim then return end
	local localChar = player.Character
	local localHRP = localChar and localChar:FindFirstChild("HumanoidRootPart")
	if not localHRP then return end
	local localPos = localHRP.Position
	local now = tick()
	local mousePos = getAimScreenPos()
	local cameraPos = camera.CFrame.Position
	local npcSearchRangeSqr = npcSearchRange * npcSearchRange
	local screenBestDist = fovSize
	local screenBestPos = nil
	local nearBestDist = nearPriorityRange + 1
	local nearBestPos = nil
	local wallChecksThisFrame = 0

	for npc, data in pairs(cachedNPCs) do
		if not data or not data.npc or not data.npc.Parent then
			cachedNPCs[npc] = nil
			continue
		end
		if whitelistDict[data.npc.Name] then continue end
		if data.humanoid.Health <= 0 then continue end
		local targetPartObj = data.targetPartObj
		if not targetPartObj or not targetPartObj.Parent then
			data.targetPartObj = getTargetPartFunc(data.npc, targetPart)
			targetPartObj = data.targetPartObj
			if not targetPartObj then continue end
		end
		local partPos = targetPartObj.Position
		if not isWithinRangeSqr(localPos, partPos, npcSearchRangeSqr) then continue end
		local aimPos = getFinalAimPoint(targetPartObj, data.hrp, data, localPos)
		if not aimPos then continue end
		local screenPos, onScreen = camera:WorldToViewportPoint(aimPos)
		if not onScreen then continue end
		local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
		if distance >= fovSize then continue end
		if checkWalls then
			if data.wallCheckVersion ~= lastWallCheckVersion or now - data.lastWallCheck > 0.1 then
				if wallChecksThisFrame < 3 then
					data.canSee = checkWall(cameraPos, aimPos, data.npc)
					data.lastWallCheck = now
					data.wallCheckVersion = lastWallCheckVersion
					wallChecksThisFrame = wallChecksThisFrame + 1
				end
			end
			if not data.canSee then continue end
		end
		if nearPriorityEnabled then
			local worldDist = (localPos - partPos).Magnitude
			if worldDist <= nearPriorityRange then
				if worldDist < nearBestDist then
					nearBestDist = worldDist
					nearBestPos = aimPos
				end
			end
			if distance < screenBestDist then
				screenBestDist = distance
				screenBestPos = aimPos
			end
		else
			if distance < screenBestDist then
				screenBestDist = distance
				screenBestPos = aimPos
			end
		end
	end

	local closestPredictedPos = nil
	if nearPriorityEnabled then
		closestPredictedPos = nearBestPos or screenBestPos
	else
		closestPredictedPos = screenBestPos
	end

	if closestPredictedPos then
		local targetCFrame = CFrame.new(camera.CFrame.Position, closestPredictedPos)
		camera.CFrame = camera.CFrame:Lerp(targetCFrame, aimSpeed)
	else
		emergencyScan()
	end
end

