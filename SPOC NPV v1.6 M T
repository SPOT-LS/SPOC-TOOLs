local function getShellHeight(contentHeight)
	return contentHeight + EXT_PAD
end

local function animateShellOpen(shell, contentHeight)
	shell.Size = UDim2.new(0, EXT_W, 0, 0)
	local tween = TweenService:Create(shell, panelTweenInfo, {Size = UDim2.new(0, EXT_W, 0, getShellHeight(contentHeight))})
	tween:Play()
	return tween
end

local function animatePanelClose(panel, callback)
	if not panel then
		if callback then callback() end
		return
	end
	local tween = TweenService:Create(panel, panelTweenInfo, {Size = UDim2.new(panel.Size.X.Scale, panel.Size.X.Offset, 0, 0)})
	tween:Play()
	tween.Completed:Connect(function()
		panel:Destroy()
		if callback then callback() end
	end)
end

closeBottomPanels = function(callback)
	local wl = whitelistShell
	local da = dropAdvShell
	local near = nearShell
	local cfg = cfgPresetShell
	whitelistShell = nil
	whitelistScroll = nil
	dropAdvShell = nil
	dropAdvFrame = nil
	nearShell = nil
	nearPanelFrame = nil
	nearRangeLabelRef = nil
	nearRangeInputRef = nil
	toggleNearPriButtonRef = nil
	dropPresetsScroll = nil
	dropAdvFarBoostRefresh = nil
	dropAdvCloseCutRefresh = nil
	cfgPresetShell = nil
	cfgPresetScroll = nil
	whitelistButton.Text = "PAV-1 WL ▼"
	dropAdvButton.Text = "Drop Adv ▼"
	cfgPresetButton.Text = "Cfg ▼"
	nearButton.Text = "Near ▼"
	local pending = 0
	if wl then pending = pending + 1 end
	if da then pending = pending + 1 end
	if near then pending = pending + 1 end
	if cfg then pending = pending + 1 end
	if pending == 0 then
		if callback then callback() end
		return
	end
	local finished = 0
	local function onOneDone()
		finished = finished + 1
		if finished >= pending and callback then
			callback()
		end
	end
	if wl then animatePanelClose(wl, onOneDone) end
	if da then animatePanelClose(da, onOneDone) end
	if near then animatePanelClose(near, onOneDone) end
	if cfg then animatePanelClose(cfg, onOneDone) end
end

local function setExtensionExpanded(expanded, animate)
	isExtensionExpanded = expanded
	extToggleBtn.Text = expanded and "◀" or "▶"
	if not expanded then
		closeBottomPanels()
	end
	local targetSize = UDim2.new(0, expanded and EXT_W or 0, 0, EXT_BAR_H)
	if animate then
		if extActiveTween then
			extActiveTween:Cancel()
			extActiveTween = nil
		end
		extActiveTween = TweenService:Create(extRoot, extTweenInfo, {Size = targetSize})
		extActiveTween:Play()
	else
		extRoot.Size = targetSize
	end
end

