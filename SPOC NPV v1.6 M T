local npcCachePending = {}
local npcCacheScheduled = false
local function scheduleNPCCache(npc)
	if not npc or not npc.Parent then return end
	npcCachePending[npc] = true
	if npcCacheScheduled then return end
	npcCacheScheduled = true
	task.delay(0.3, function()
		npcCacheScheduled = false
		for model in pairs(npcCachePending) do
			npcCachePending[model] = nil
			if model.Parent then
				cacheNPC(model)
			end
		end
	end)
end

