local function getPlayerFromCharacter(char)
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr.Character == char then
			return plr
		end
	end
	return nil
end

local function isValidPlayerTarget(obj)
	if not obj:IsA("Model") then return false end
	if not obj:FindFirstChildOfClass("Humanoid") then return false end
	local hrp = obj:FindFirstChild("HumanoidRootPart")
	if not hrp then return false end
	local owner = getPlayerFromCharacter(obj)
	if not owner or owner == player then return false end
	return true, hrp, owner
end

