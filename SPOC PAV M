local function persistSettingsPresets()
	if not canPersistFiles() then return end
	pcall(function()
		writefile(PRESET_STORE, HttpService:JSONEncode({presets = settingsPresets}))
	end)
end

local function loadSettingsPresets()
	if not canPersistFiles() then return end
	pcall(function()
		if isfile(PRESET_STORE) then
			local raw = readfile(PRESET_STORE)
			local data = HttpService:JSONDecode(raw)
			if type(data) == "table" and type(data.presets) == "table" then
				settingsPresets = {}
				for _, preset in ipairs(data.presets) do
					if type(preset) == "table" and type(preset.name) == "string" and type(preset.data) == "table" then
						table.insert(settingsPresets, {
							id = type(preset.id) == "string" and preset.id or HttpService:GenerateGUID(false),
							name = preset.name,
							data = preset.data,
						})
					end
				end
			end
		end
	end)
end

local function updateWhitelistDict()
	whitelistDict = {}
	for _, name in ipairs(whitelist) do
		whitelistDict[name] = true
	end
end

