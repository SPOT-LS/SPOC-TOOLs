local function getFovShouldShow()
	if isSilentAimEnabled then
		return showFovCircle
	end
	if not aimFovSyncActive then
		return showFovCircle
	end
	return false
end

function updateFovCircle()
	if fovCircle and fovGui then
		fovCircle.Size = UDim2.new(0, fovSize * 2, 0, fovSize * 2)
		fovCircle.Position = UDim2.new(0.5, 0, 0.5, 0)
		fovCircle.AnchorPoint = Vector2.new(0.5, 0.5)
		fovCircle.Visible = getFovShouldShow()
	end
end

refreshFovVisibility = function()
	local shouldShow = getFovShouldShow()
	if shouldShow then
		if not fovCircle then createFovCircle() end
		updateFovCircle()
	elseif fovCircle then
		fovCircle.Visible = false
	end
end

local function resolveTargetVelocity(targetPartObj, targetRootPart, data)
	local vel = Vector3.zero
	if targetRootPart then
		vel = targetRootPart.AssemblyLinearVelocity
		if vel.Magnitude < 0.01 then
			vel = targetRootPart.Velocity
		end
	end
	if data and data.lastPartPos and data.lastPredTick then
		local now = tick()
		local dt = now - data.lastPredTick
		if dt > 0.001 and dt < 0.35 then
			local deltaVel = (targetPartObj.Position - data.lastPartPos) / dt
			if deltaVel.Magnitude > 0.5 then
				if vel.Magnitude < 1 or deltaVel.Magnitude > vel.Magnitude * 0.85 then
					vel = deltaVel
				end
			end
		end
	end
	if vel.Magnitude < 0.01 and data and data.lastRootPos and data.lastRootTick then
		local dt = tick() - data.lastRootTick
		if dt > 0.001 and dt < 0.35 and targetRootPart then
			local rootDelta = (targetRootPart.Position - data.lastRootPos) / dt
			if rootDelta.Magnitude > 0.5 then
				vel = rootDelta
			end
		end
	end
	return vel
end

local function sampleTargetMotion(data, targetPartObj, targetRootPart)
	if not data or not targetPartObj then return end
	local now = tick()
	data.lastPartPos = targetPartObj.Position
	data.lastPredTick = now
	if targetRootPart then
		data.lastRootPos = targetRootPart.Position
		data.lastRootTick = now
	end
end

local function getPredictedPosition(targetPartObj, targetRootPart, data)
	if not targetPartObj then return nil end
	sampleTargetMotion(data, targetPartObj, targetRootPart)
	if not predictionEnabled or predictionAmount <= 0 then
		return targetPartObj.Position
	end
	local vel = resolveTargetVelocity(targetPartObj, targetRootPart, data)
	return targetPartObj.Position + (vel * predictionAmount * 0.1)
end

local function applyBallisticElev(localPos, aimPos)
	if not dropEnabled or dropAmount <= 0 then
		return aimPos
	end
	local dist = (aimPos - localPos).Magnitude
	if dist < 1 then
		return aimPos
	end
	local refDist = math.clamp(playerSearchRange * 0.4, 60, 500)
	local curvePower = 1.5 + (dropFarBoost / 100) * 2.5
	local nearDist = 10 + ((100 - dropCloseCut) / 100) * 40
	local strength = 0.008 + (dropFarBoost / 100) * 0.025
	local rangeRatio = dist / refDist
	local ballisticCurve = math.pow(rangeRatio, curvePower)
	local nearBlend = math.clamp(dist / nearDist, 0, 1)
	ballisticCurve = ballisticCurve * nearBlend
	local elev = dropAmount * ballisticCurve * refDist * strength
	return aimPos + Vector3.new(0, elev, 0)
end

local function getFinalAimPoint(targetPartObj, targetRootPart, data, localPos)
	local predicted = getPredictedPosition(targetPartObj, targetRootPart, data)
	if not predicted then return nil end
	return applyBallisticElev(localPos, predicted)
end

local function isWithinRangeSqr(pos1, pos2, rangeSqr)
	local dx = pos1.X - pos2.X
	local dy = pos1.Y - pos2.Y
	local dz = pos1.Z - pos2.Z
	return (dx * dx + dy * dy + dz * dz) <= rangeSqr
end

local function cachePlayerCharacter(char)
	if not char or not char.Parent then return end
	local isValid, hrp, plr = isValidPlayerTarget(char)
	if not isValid then return end
	local humanoid = char:FindFirstChildWhichIsA("Humanoid")
	local targetPartObj = getTargetPartFunc(char, targetPart)
	if humanoid and hrp and targetPartObj then
		local now = tick()
		cachedPlayers[char] = {
			character = char,
			player = plr,
			hrp = hrp,
			humanoid = humanoid,
			targetPartObj = targetPartObj,
			lastUpdate = now,
			lastWallCheck = 0,
			canSee = false,
			wallCheckVersion = 0,
			lastPartPos = targetPartObj.Position,
			lastPredTick = now,
			lastRootPos = hrp.Position,
			lastRootTick = now,
		}
	end
end

local function uncachePlayerCharacter(char)
	cachedPlayers[char] = nil
end

local function checkWall(cameraPos, targetPos, targetCharacter)
	local direction = targetPos - cameraPos
	local maxDistance = direction.Magnitude
	if maxDistance < 0.01 then return true end
	direction = direction.Unit
	resetWallBlacklist()
	local blacklist = wallBlacklist
	local currentDistance = maxDistance
	local currentOrigin = cameraPos
	for _ = 1, 50 do
		if currentDistance <= 0.01 then return true end
		wallRayParams.FilterDescendantsInstances = blacklist
		local raycastResult = Workspace:Raycast(currentOrigin, direction * currentDistance, wallRayParams)
		if not raycastResult then return true end
		local hitInstance = raycastResult.Instance
		if hitInstance:IsDescendantOf(targetCharacter) then
			return true
		end
		local shouldIgnore = false
		if ignoreCanCollideWalls and not hitInstance.CanCollide then
			shouldIgnore = true
		elseif ignoreTransparentWalls and hitInstance.Transparency > 0.9 then
			shouldIgnore = true
		end
		if shouldIgnore then
			table.insert(blacklist, hitInstance)
			currentOrigin = raycastResult.Position
			currentDistance = (targetPos - currentOrigin).Magnitude
		else
			return false
		end
	end
	return false
end

local lastEmergencyScan = 0

local function emergencyScan()
	local now = tick()
	if now - lastEmergencyScan < 0.5 then return end
	lastEmergencyScan = now
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character and not cachedPlayers[plr.Character] then
			cachePlayerCharacter(plr.Character)
		end
	end
end

