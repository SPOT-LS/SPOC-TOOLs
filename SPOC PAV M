local function applyPreset(preset)
	if not preset then return end
	if type(preset.dropAmount) == "number" then dropAmount = preset.dropAmount end
	if type(preset.farBoost) == "number" then dropFarBoost = preset.farBoost end
	if type(preset.closeCut) == "number" then dropCloseCut = preset.closeCut end
	updateDropDisplay()
	refreshAdvDropDisplays()
end

local function getPresetColor(preset)
	if preset.r and preset.g and preset.b then
		return Color3.fromRGB(preset.r, preset.g, preset.b)
	end
	return PRESET_COLORS[1]
end

local function cyclePresetColor(preset)
	local current = getPresetColor(preset)
	local idx = 1
	for i, col in ipairs(PRESET_COLORS) do
		if math.abs(col.R - current.R) < 0.01 and math.abs(col.G - current.G) < 0.01 and math.abs(col.B - current.B) < 0.01 then
			idx = i
			break
		end
	end
	local nextIdx = (idx % #PRESET_COLORS) + 1
	local col = PRESET_COLORS[nextIdx]
	preset.r = math.floor(col.R * 255 + 0.5)
	preset.g = math.floor(col.G * 255 + 0.5)
	preset.b = math.floor(col.B * 255 + 0.5)
end

local function createDropAdvRow(parent, yPos, labelText, getVal, setVal)
	local rowLabel = Instance.new("TextLabel")
	rowLabel.Size = UDim2.new(1, 0, 0, 14)
	rowLabel.Position = UDim2.new(0, 0, 0, yPos)
	rowLabel.BackgroundTransparency = 1
	rowLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	rowLabel.Text = labelText .. ": " .. getVal()
	rowLabel.Font = Enum.Font.SourceSans
	rowLabel.TextSize = 11
	rowLabel.TextXAlignment = Enum.TextXAlignment.Left
	rowLabel.Parent = parent
	local rowFrame = Instance.new("Frame")
	rowFrame.Size = UDim2.new(1, 0, 0, 16)
	rowFrame.Position = UDim2.new(0, 0, 0, yPos + 14)
	rowFrame.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
	rowFrame.BorderSizePixel = 0
	rowFrame.Parent = parent
	local decBtn = Instance.new("TextButton")
	decBtn.Size = UDim2.new(0.2, 0, 1, 0)
	decBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
	decBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	decBtn.Text = "-"
	decBtn.Font = Enum.Font.SourceSansBold
	decBtn.TextSize = 12
	decBtn.Parent = rowFrame
	local inputBox = Instance.new("TextBox")
	inputBox.Size = UDim2.new(0.6, 0, 1, 0)
	inputBox.Position = UDim2.new(0.2, 0, 0, 0)
	inputBox.BackgroundColor3 = Color3.fromRGB(120, 120, 120)
	inputBox.TextColor3 = Color3.fromRGB(255, 255, 255)
	inputBox.Text = tostring(getVal())
	inputBox.Font = Enum.Font.SourceSans
	inputBox.TextSize = 11
	inputBox.ClearTextOnFocus = false
	inputBox.Parent = rowFrame
	local incBtn = Instance.new("TextButton")
	incBtn.Size = UDim2.new(0.2, 0, 1, 0)
	incBtn.Position = UDim2.new(0.8, 0, 0, 0)
	incBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
	incBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	incBtn.Text = "+"
	incBtn.Font = Enum.Font.SourceSansBold
	incBtn.TextSize = 12
	incBtn.Parent = rowFrame
	local function refresh()
		local v = getVal()
		rowLabel.Text = labelText .. ": " .. v
		inputBox.Text = tostring(v)
	end
	local function applyNum(num)
		if not num then
			refresh()
			return
		end
		num = math.floor(num + 0.5)
		setVal(num)
		refresh()
	end
	decBtn.Activated:Connect(function()
		applyNum(getVal() - 1)
	end)
	incBtn.Activated:Connect(function()
		applyNum(getVal() + 1)
	end)
	inputBox.FocusLost:Connect(function()
		applyNum(tonumber(inputBox.Text))
	end)
	return rowLabel, inputBox
end

