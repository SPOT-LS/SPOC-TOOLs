function updateClickBtnState()
	if auto_click_running then
		clickBtn:WaitForChild("Name").Text = "Auto Click: RUNNING..."
		return
	end
	local now = tick()
	local elapsed = now - auto_click_last_end
	if elapsed < AUTO_CLICK_COOLDOWN then
		local remain = math.ceil(AUTO_CLICK_COOLDOWN - elapsed)
		clickBtn:WaitForChild("Name").Text = "Cooldown: " .. remain .. "s"
	else
		clickBtn:WaitForChild("Name").Text = "Auto Click: Ready (Tap)"
		auto_click_cooldown_active = false
	end
end

clickBtn.MouseButton1Click:Connect(function()
	if auto_click_running then return end
	local now = tick()
	if now - auto_click_last_end < AUTO_CLICK_COOLDOWN then return end
	local key = keyInput.Text:upper()
	if #key ~= 1 then
		clickBtn:WaitForChild("Name").Text = "Invalid Key!"
		task.delay(1, updateClickBtnState)
		return
	end
	local keyCode = Enum.KeyCode[key]
	if not keyCode then
		clickBtn:WaitForChild("Name").Text = "Invalid Key!"
		task.delay(1, updateClickBtnState)
		return
	end
	auto_click_key = key
	auto_click_running = true
	updateClickBtnState()
	task.spawn(function()
		local vim = game:GetService("VirtualInputManager")
		local startTime = tick()
		local interval = 1 / math.max(1, auto_click_speed)
		while tick() - startTime < auto_click_duration do
			vim:SendKeyEvent(true, keyCode, false, game)
			task.wait(interval / 2)
			vim:SendKeyEvent(false, keyCode, false, game)
			task.wait(interval)
		end
		auto_click_running = false
		auto_click_last_end = tick()
		auto_click_cooldown_active = true
		updateClickBtnState()
	end)
end)

addSlider("Click Duration (sec)", 0, 20000, 3, function(value)
	auto_click_duration = value
end)

addSlider("Click Speed (per sec)", 5000, 50000, 50000, function(value)
	auto_click_speed = value
end)

if instant_interact_enabled then
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("ProximityPrompt") then
			original_hold_durations[obj] = obj.HoldDuration
			table.insert(cached_prompts, obj)
			obj.HoldDuration = 0
		end
	end
end

local function keepOnTop()
	local parent = GUI_PARENT
	if SPOC.Parent ~= parent then
		SPOC.Parent = parent
	end
	SPOC.DisplayOrder = DISPLAY_ORDER
	local currentParent = SPOC.Parent
	if currentParent then
		SPOC.Parent = nil
		SPOC.Parent = currentParent
	end
end

GuiService.MenuOpened:Connect(keepOnTop)

RunService.RenderStepped:Connect(function()
	if esp_enabled then
		update_esp()
	else
		for _, objects in pairs(esp_objects) do
			for _, obj in pairs(objects) do
				obj.Visible = false
			end
		end
	end
	updateWhitelistButtonPosition()
	if auto_click_cooldown_active and not auto_click_running then
		updateClickBtnState()
	end
	if SPOC.DisplayOrder < DISPLAY_ORDER then
		SPOC.DisplayOrder = DISPLAY_ORDER
	end
	if GuiService.MenuIsOpen then
		keepOnTop()
	end
end)

