local function is_target_behind_wall(character, targetPart)
	if not character or not targetPart then
		return false
	end
	local origin = Camera.CFrame.Position
	local targetPos = targetPart.Position
	local direction = targetPos - origin
	local distance = direction.Magnitude
	if distance < 0.1 then
		return false
	end
	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	local filterList = {}
	if LocalPlayer.Character then
		table.insert(filterList, LocalPlayer.Character)
	end
	rayParams.FilterDescendantsInstances = filterList
	local result = Workspace:Raycast(origin, direction.Unit * distance, rayParams)
	if not result then
		return false
	end
	local hit = result.Instance
	if hit:IsDescendantOf(character) then
		return false
	end
	local hitModel = hit:FindFirstAncestorOfClass("Model")
	if hitModel == character then
		return false
	end
	return true
end

local function update_esp()
	for player, objects in pairs(esp_objects) do
		local character = player.Parent and player.Character
		local hrp = character and character:FindFirstChild("HumanoidRootPart")
		local head = character and character:FindFirstChild("Head")
		if not hrp or not head then
			for _, obj in pairs(objects) do obj.Visible = false end
			continue
		end
		if player == LocalPlayer then
			for _, obj in pairs(objects) do obj.Visible = false end
			continue
		end
		if esp_team_check and player.Team == LocalPlayer.Team then
			for _, obj in pairs(objects) do obj.Visible = false end
			continue
		end
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
		local headPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
		local legPos = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
		if onScreen and esp_enabled then
			local distance = (hrp.Position - Camera.CFrame.Position).Magnitude
			local dynamicFontSize = getDistanceScaledFontSize(esp_font_size, distance)
			local boxHeight = math.abs(headPos.Y - legPos.Y)
			if boxHeight < 2 then
				for _, obj in pairs(objects) do obj.Visible = false end
				continue
			end
			local boxWidth = math.max(boxHeight * 0.35, 2)
			local topLeft = Vector2.new(pos.X - boxWidth / 2, math.min(headPos.Y, legPos.Y))
			local topRight = Vector2.new(pos.X + boxWidth /  2, math.min(headPos.Y, legPos.Y))
			local bottomLeft = Vector2.new(pos.X - boxWidth / 2, math.max(headPos.Y, legPos.Y))
			local bottomRight = Vector2.new(pos.X + boxWidth / 2, math.max(headPos.Y, legPos.Y))
			local drawColor = esp_box_color
			if esp_wall_color_enabled then
				drawColor = is_target_behind_wall(character, hrp) and esp_wall_color_1 or esp_wall_color_2
			end
			objects.BoxTop.Color = drawColor
			objects.BoxBottom.Color = drawColor
			objects.BoxLeft.Color = drawColor
			objects.BoxRight.Color = drawColor
			objects.Tracer.Color = drawColor
			if esp_boxes then
				objects.BoxTop.From = topLeft
				objects.BoxTop.To = topRight
				objects.BoxTop.Visible = true
				objects.BoxBottom.From = bottomLeft
				objects.BoxBottom.To = bottomRight
				objects.BoxBottom.Visible = true
				objects.BoxLeft.From = topLeft
				objects.BoxLeft.To = bottomLeft
				objects.BoxLeft.Visible = true
				objects.BoxRight.From = topRight
				objects.BoxRight.To = bottomRight
				objects.BoxRight.Visible = true
			else
				objects.BoxTop.Visible = false
				objects.BoxBottom.Visible = false
				objects.BoxLeft.Visible = false
				objects.BoxRight.Visible = false
			end
			local currentY = topLeft.Y - 4
			if esp_names then
				objects.Name.Size = dynamicFontSize
				objects.Name.Text = player.Name
				objects.Name.Position = Vector2.new(pos.X, currentY - 8)
				objects.Name.Visible = true
				currentY = currentY - 10
			else
				objects.Name.Visible = false
			end
			if esp_health and humanoid then
				objects.Health.Size = dynamicFontSize
				objects.Health.Text = math.floor(humanoid.Health) .. "/" .. math.floor(humanoid.MaxHealth)
				objects.Health.Position = Vector2.new(pos.X, bottomLeft.Y + 4)
				objects.Health.Visible = true
			else
				objects.Health.Visible = false
			end
			if esp_distance then
				objects.Distance.Size = dynamicFontSize
				objects.Distance.Text = "[" .. math.floor(distance) .. "m]"
				objects.Distance.Position = Vector2.new(pos.X, bottomLeft.Y + (esp_health and 12 or 4))
				objects.Distance.Visible = true
			else
				objects.Distance.Visible = false
			end
			if esp_tracers then
				objects.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
				objects.Tracer.To = Vector2.new(pos.X, pos.Y)
				objects.Tracer.Visible = true
			else
				objects.Tracer.Visible = false
			end
		else
			for _, obj in pairs(objects) do obj.Visible = false end
		end
	end
end

local fly_enabled = false
