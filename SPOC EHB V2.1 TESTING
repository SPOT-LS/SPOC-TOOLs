local function addSlider(name, min, max, default, funct, ...)
	local newSlider = Slider:Clone()
	local args = {...}
	local value = default
	local dragging = false
	local sliderBar = newSlider:WaitForChild("SliderBar")
	local sliderBtn = sliderBar:WaitForChild("SliderButton")
	local range = math.max(max - min, 1)
	local function updateSlider(input)
		local pos = math.clamp((input.Position.X - sliderBar.AbsolutePosition.X) / sliderBar.AbsoluteSize.X, 0, 1)
		value = math.floor(min + range * pos)
		sliderBtn.Position = UDim2.new(pos, 0, 0.5, 0)
		newSlider:WaitForChild("SliderName").Text = name .. ": " .. value
		funct(value, unpack(args))
	end
	sliderBtn.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateSlider(input)
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	newSlider:WaitForChild("SliderName").Text = name .. ": " .. default
	newSlider.Size = UDim2.new(0.95, 0, 0, element_height)
	newSlider.Name = name
	newSlider.Parent = Menu
	newSlider.LayoutOrder = elements
	newSlider.Visible = true
	elements += 1
	addSpace(Menu)
	local initialPos = (default - min) / range
	sliderBtn.Position = UDim2.new(initialPos, 0, 0.5, 0)
	return newSlider
end

