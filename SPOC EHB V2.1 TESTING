local function add_to_whitelist(userId)
	if not whitelist_lookup[userId] then
		table.insert(hitbox_whitelist, userId)
		whitelist_lookup[userId] = true
		save_whitelist(hitbox_whitelist)
	end
end

local function remove_from_whitelist(userId)
	if whitelist_lookup[userId] then
		whitelist_lookup[userId] = nil
		local idx = table.find(hitbox_whitelist, userId)
		if idx then
			table.remove(hitbox_whitelist, idx)
		end
		save_whitelist(hitbox_whitelist)
	end
end

