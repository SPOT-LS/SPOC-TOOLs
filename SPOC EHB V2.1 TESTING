local cached_prompts = {}
local prompt_add_queue = {}
local prompt_remove_queue = {}
local original_hold_durations = {}

Workspace.DescendantAdded:Connect(function(descendant)
	if descendant:IsA("ProximityPrompt") then
		table.insert(prompt_add_queue, descendant)
	end
end)

Workspace.DescendantRemoving:Connect(function(descendant)
	if descendant:IsA("ProximityPrompt") then
		table.insert(prompt_remove_queue, descendant)
	end
end)

local function process_prompt_queues()
	for _, prompt in ipairs(prompt_add_queue) do
		if prompt and prompt.Parent then
			if original_hold_durations[prompt] == nil then
				original_hold_durations[prompt] = prompt.HoldDuration
			end
			table.insert(cached_prompts, prompt)
			if instant_interact_enabled then
				prompt.HoldDuration = 0
			end
		end
	end
	prompt_add_queue = {}
	for _, prompt in ipairs(prompt_remove_queue) do
		for i, cached in ipairs(cached_prompts) do
			if cached == prompt then
				table.remove(cached_prompts, i)
				break
			end
		end
		original_hold_durations[prompt] = nil
	end
	prompt_remove_queue = {}
end

local lastAutoInteract = 0
local AUTO_INTERACT_INTERVAL = 0.15

local function updateAutoInteract()
	if not auto_interact_enabled then return end
	local now = tick()
	if now - lastAutoInteract < AUTO_INTERACT_INTERVAL then return end
	lastAutoInteract = now
	local character = LocalPlayer.Character
	local hrp = character and character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local localPos = hrp.Position
	for _, obj in ipairs(cached_prompts) do
		if obj and obj.Parent then
			local parent = obj.Parent
			if parent and parent:IsA("BasePart") then
				local dist = (localPos - parent.Position).Magnitude
				if dist <= interact_distance and dist <= obj.MaxActivationDistance then
					if obj.Enabled then
						fireproximityprompt(obj)
					end
				end
			end
		end
	end
end

