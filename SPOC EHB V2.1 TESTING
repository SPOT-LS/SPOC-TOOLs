local noclip_descendant_connection = nil

local function record_character_collisions(character)
	if not character then return end
	for _, part in ipairs(character:GetDescendants()) do
		if part:IsA("BasePart") and noclip_original_states[part] == nil then
			noclip_original_states[part] = part.CanCollide
		end
	end
end

local function apply_noclip_to_character(character)
	if not character then return end
	for _, part in ipairs(character:GetDescendants()) do
		if part:IsA("BasePart") then
			if noclip_original_states[part] == nil then
				noclip_original_states[part] = part.CanCollide
			end
			part.CanCollide = false
		end
	end
end

local function restore_noclip_states()
	for part, original_state in pairs(noclip_original_states) do
		if part and part.Parent then
			part.CanCollide = original_state
		end
	end
	noclip_original_states = {}
end

local function start_noclip()
	local character = LocalPlayer.Character
	if not character then return end
	record_character_collisions(character)
	apply_noclip_to_character(character)
	noclip_connection = RunService.Stepped:Connect(function()
		if not noclip_enabled then return end
		local char = LocalPlayer.Character
		if char then apply_noclip_to_character(char) end
	end)
	noclip_descendant_connection = character.DescendantAdded:Connect(function(descendant)
		if not noclip_enabled then return end
		if descendant:IsA("BasePart") then
			if noclip_original_states[descendant] == nil then
				noclip_original_states[descendant] = descendant.CanCollide
			end
			descendant.CanCollide = false
		end
	end)
end

local function stop_noclip()
	if noclip_connection then
		noclip_connection:Disconnect()
		noclip_connection = nil
	end
	if noclip_descendant_connection then
		noclip_descendant_connection:Disconnect()
		noclip_descendant_connection = nil
	end
	restore_noclip_states()
end

