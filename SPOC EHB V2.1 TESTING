local noop = function() end
local silentNames = {
	"print", "warn", "error",
	"rconsoleprint", "rconsolewarn", "rconsoleerr", "rconsoleinfo", "rconsoleclear", "rconsolename", "rconsoleinput",
	"rprint", "logprint", "logwarn", "logerror", "loginfo", "logmessage",
	"consoleprint", "consolewarn", "consoleerr", "consoleinfo", "consoleclear", "consoleinput",
	"messagebox", "messageboxasync", "notify", "notification",
}
local logServiceHooked = false
local function silenceTarget(target)
	if type(target) ~= "table" then return end
	for _, name in ipairs(silentNames) do
		if type(target[name]) == "function" then
			target[name] = noop
		end
	end
end
local function enforceRadioSilence()
	silenceTarget(_G)
	silenceTarget(getgenv())
	silenceTarget(shared)
	if type(debug) == "table" and type(debug.info) == "function" then
		debug.info = noop
	end
	if not logServiceHooked then
		game:GetService("LogService").MessageOut:Connect(function() end)
		logServiceHooked = true
	end
end
enforceRadioSilence()
task.spawn(function()
	while true do
		task.wait(3)
		enforceRadioSilence()
	end
end)

