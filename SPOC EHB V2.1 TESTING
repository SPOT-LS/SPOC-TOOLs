local function colorToTable(color)
	return {
		math.floor(color.R * 255 + 0.5),
		math.floor(color.G * 255 + 0.5),
		math.floor(color.B * 255 + 0.5),
	}
end

local function tableToColor(data, fallback)
	if type(data) == "table" and type(data[1]) == "number" and type(data[2]) == "number" and type(data[3]) == "number" then
		return Color3.fromRGB(
			math.clamp(math.floor(data[1]), 0, 255),
			math.clamp(math.floor(data[2]), 0, 255),
			math.clamp(math.floor(data[3]), 0, 255)
		)
	end
	return fallback
end

local function normalizeColorTable(data, fallback)
	local color = tableToColor(data, fallback)
	return colorToTable(color)
end

