local function getDistanceScaledFontSize(baseSize, distance)
	local scaleFactor = math.clamp(1000 / distance, 0.4, 1.8)
	local finalSize = math.floor(baseSize * scaleFactor)
	return math.clamp(finalSize, esp_min_font_size, esp_max_font_size)
end

local function save_original_part_properties(player, part)
	if not hitbox_original_properties[player] then
		hitbox_original_properties[player] = {}
	end
	if not hitbox_original_properties[player][part.Name] then
		hitbox_original_properties[player][part.Name] = {
			CanCollide = part.CanCollide,
			Transparency = part.Transparency,
			Size = part.Size,
		}
	end
end

local function restore_character_parts(player, character)
	if not hitbox_original_properties[player] or not character then return end
	for part_name, original_properties in pairs(hitbox_original_properties[player]) do
		local part = character:FindFirstChild(part_name)
		if part and part:IsA("BasePart") then
			part.CanCollide = original_properties.CanCollide
			part.Transparency = original_properties.Transparency
			part.Size = original_properties.Size
		end
	end
end

local function restore_original_part_properties(player)
	if hitbox_original_properties[player] then
		local character = player.Character
		if character then
			restore_character_parts(player, character)
		end
	end
end

local function isWithinRange(pos1, pos2, range)
	local dx = pos1.X - pos2.X
	local dy = pos1.Y - pos2.Y
	local dz = pos1.Z - pos2.Z
	return (dx*dx + dy*dy + dz*dz) <= (range*range)
end

local function modify_player_hitbox(player, enable_hitbox, no_collision)
	for _, part_name in ipairs(hitbox_target_parts) do
		local part = player.Character and player.Character:FindFirstChild(part_name)
		if part and part:IsA("BasePart") then
			if enable_hitbox then
				save_original_part_properties(player, part)
				part.CanCollide = not no_collision
				part.Transparency = math.clamp(hitbox_transparency, 0, 1)
				part.Size = Vector3.new(hitbox_size, hitbox_size, hitbox_size)
			else
				restore_original_part_properties(player)
			end
		end
	end
end

local function is_target_player_hitbox(target_player)
	if is_whitelisted(target_player.UserId) then
		return false
	end
	if hitbox_team_check_mode == "FFA" or hitbox_team_check_mode == "Everyone" then
		return true
	end
	if hitbox_team_check_mode == "Team-Based" then
		return target_player.Team ~= LocalPlayer.Team
	end
	return target_player.Team ~= LocalPlayer.Team
end

local function update_all_player_hitboxes(enable_hitbox, no_collision)
	local localChar = LocalPlayer.Character
	local localHRP = localChar and localChar:FindFirstChild("HumanoidRootPart")
	local localPos = localHRP and localHRP.Position
	for _, player in ipairs(cached_players) do
		if player ~= LocalPlayer then
			local character = player.Character
			local targetHRP = character and character:FindFirstChild("HumanoidRootPart")
			if targetHRP then
				local inRange = not localPos or isWithinRange(localPos, targetHRP.Position, hitbox_search_range)
				if enable_hitbox and is_target_player_hitbox(player) and inRange then
					modify_player_hitbox(player, true, no_collision)
				else
					modify_player_hitbox(player, false, no_collision)
				end
			end
		end
	end
end

local function cleanup_removed_players_data()
	for player, _ in pairs(hitbox_original_properties) do
		if not player.Parent then
			hitbox_original_properties[player] = nil
		end
	end
end

local function setup_player_character_handlers(player)
	if player == LocalPlayer then return end
	if player_char_connections[player] then
		for _, conn in ipairs(player_char_connections[player]) do
			conn:Disconnect()
